# Leave unset for local dev — requests go through Vite's dev proxy (see
# vite.config.js) to the backend on localhost:5050.
#
# Set this in production when the frontend and backend are separate
# deployments (e.g. Vercel for this client, Render for the server) — use
# the backend's full public URL, no trailing slash.
VITE_API_BASE_URL=https://your-backend.onrender.com
