PORT=5050
MONGO_URI=mongodb://127.0.0.1:27017/site-builder
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# Absolute origin of this backend, baked into exported contact form actions so
# they keep working once the static site is hosted elsewhere (e.g. cPanel).
PUBLIC_API_BASE_URL=http://localhost:5050

# AI features: set AI_PROVIDER to "gemini" or "openai" to force one, or leave blank
# to auto-detect (prefers Gemini if GEMINI_API_KEY is set).
AI_PROVIDER=gemini

# Gemini (free tier via https://aistudio.google.com/apikey — no card required)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (requires billing/credits)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
